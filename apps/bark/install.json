{
  "id": "bark",
  "name": "Bark TTS",
  "version": "1.0",
  "run": [
    {
      "method": "git",
      "name": "Клонировать Bark WebUI",
      "url": "https://github.com/cocktailpeanutlabs/bark"
    },
    {
      "method": "pip",
      "name": "Установить Bark",
